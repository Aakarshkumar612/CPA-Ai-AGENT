# Copy this to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud: paste these in the app's Secrets settings panel instead.

GROQ_API_KEY = "gsk_..."

# Optional — leave blank to use mock freight rates
APIFY_API_TOKEN = ""

# Set to "false" to use real Apify (requires APIFY_API_TOKEN above)
USE_MOCK_APIFY = "true"
