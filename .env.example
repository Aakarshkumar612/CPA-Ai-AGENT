# ============================================
# Crowd Wisdom Trading CPA AI Agent
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control!
# All settings are validated at startup by utils/settings.py (Pydantic).

# ── LLM ──────────────────────────────────────────────────
# Groq API key (REQUIRED). Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for classification and extraction (optional)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Apify (Market Data Scraping) ──────────────────────────
# Apify token. If unset, USE_MOCK_APIFY is forced true.
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here

# Use mock freight rates (true = free demo, false = real Apify scraping)
USE_MOCK_APIFY=true

# ── Database ──────────────────────────────────────────────
# SQLAlchemy URL. Default is a local SQLite file.
DATABASE_URL=sqlite:///cpa_agent.db

# ── Benchmarking ──────────────────────────────────────────
# Price deviation threshold (%) above which a line item is flagged
BENCHMARK_THRESHOLD_PERCENT=15.0

# ── Caching ───────────────────────────────────────────────
# How long Docling + LLM cache entries stay valid (hours)
CACHE_TTL_HOURS=24.0

# ── Logging ───────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
